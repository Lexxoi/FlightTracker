  <Script file="mapicons.lua"/>

  <!-- Flight master icon template -->
  <Button name="FTMapIconTemplate" hidden="true" virtual="true">
    <Size><AbsDimension x="16" y="16"/></Size>
    <NormalTexture file="Interface\TaxiFrame\UI-Taxi-Icon-Green"/>
    <HighlightTexture file="Interface\TaxiFrame\UI-Taxi-Icon-Highlight">
      <Size x="32" y="32"/>
      <Anchors>
        <Anchor point="CENTER">
          <Offset><AbsDimension x="0" y="0"/></Offset>
        </Anchor>
      </Anchors>
    </HighlightTexture>
    <Scripts>
      <OnEnter>FlightTracker_MapIcon_OnEnter(this);</OnEnter>
      <OnLeave>FlightTracker_MapIcon_OnLeave(this);</OnLeave>
    </Scripts>
  </Button>

  <!-- Flight line texture template -->
  <Texture name="FTMapLineTemplate" hidden="true" virtual="true"
           file="Interface\AddOns\FlightTracker\img\lineup">
    <Size><AbsDimension x="256" y="256"/></Size>
    <Anchors><Anchor point="TOPLEFT"/></Anchors>
  </Texture>

